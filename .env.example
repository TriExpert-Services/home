# Production .env for LXC 100 (`/home/.env`).
# Copy to .env and fill in real values. Do not commit the real .env.

# --- Supabase --------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# --- n8n webhooks (still hit directly from the bundle) ---------------------
# Translation form
VITE_N8N_WEBHOOK_URL=https://app.n8n-tech.cloud/webhook/triexpert-translate
# Contact form
VITE_N8N_CONTACT_WEBHOOK_URL=https://app.n8n-tech.cloud/webhook/triexpert-contact

# (The chatbot webhook is now proxied through the Supabase
#  `chatbot-relay` edge function — its URL/secret live in supabase secrets,
#  not here.)

# --- Container port mapping ------------------------------------------------
HOST_PORT=8080
CONTAINER_PORT=80
